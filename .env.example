# ────────────────────────────────────────────────────────────────────
# Server-side secrets (Vercel project → Settings → Environment Variables)
# ────────────────────────────────────────────────────────────────────
# These are read by /api/ai/gemini and /api/ai/anthropic serverless
# functions. They are NEVER exposed to the browser.

GEMINI_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# ────────────────────────────────────────────────────────────────────
# Browser-side config (prefixed with VITE_ so Vite exposes them)
# ────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: pin a Gemini key into the build for local dev only.
# Leave blank in production — the serverless proxy is preferred.
# VITE_GEMINI_API_KEY=
